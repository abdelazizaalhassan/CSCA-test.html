  <table class="ctable">
    <tr><th>Method</th><th>Principle</th><th>Application</th><th>Equipment</th></tr>
    <tr><td><strong>Filtration</strong></td><td>Separate insoluble solid from liquid</td><td>Remove sand from salt water; isolate precipitate</td><td>Funnel, filter paper, beaker, glass rod</td></tr>
    <tr><td><strong>Evaporation</strong></td><td>Remove solvent to concentrate solute</td><td>Obtain NaCl crystals from seawater</td><td>Evaporating dish, alcohol lamp</td></tr>
    <tr><td><strong>Distillation</strong></td><td>Separate liquids with different boiling points</td><td>Purify water; separate ethanol from water</td><td>Round-bottom flask, condenser, thermometer, receiver</td></tr>
    <tr><td><strong>Extraction</strong></td><td>Use immiscible solvent ("like dissolves like")</td><td>Extract Br₂ from water using CCl₄ or petroleum ether</td><td>Separating funnel</td></tr>
    <tr><td><strong>Chromatography</strong></td><td>Components travel at different rates on stationary phase</td><td>Separate dyes, analyse plant pigments</td><td>Chromatography paper or column</td></tr>
