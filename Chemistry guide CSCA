<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CSCA Chemistry — Complete Prep Guide</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,500&family=Source+Serif+4:opsz,wght@8..60,300;8..60,400;8..60,600;8..60,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>

:root{
  --cream:#fdf9f4;--warm:#f5ede0;--border:#e0d3c0;--border2:#c4a882;
  --text:#231a10;--muted:#6b5040;--light:#9c7f60;
  --green:#1a7a3c;--green-bg:#d6f0e0;--green-light:#eafaf0;
  --blue:#0a4d8c;--blue-bg:#d0e8ff;--blue-light:#ebf5ff;
  --amber:#b07800;--amber-bg:#fff2c2;--amber-light:#fffae8;
  --red:#a01c1c;--red-bg:#ffd8d8;--red-light:#fff0f0;
  --purple:#5a2d9a;--purple-bg:#ede0ff;--purple-light:#f8f4ff;
  --teal:#0a7a64;--teal-bg:#c8f0e8;--teal-light:#eafaf7;
  --shadow:0 2px 12px rgba(0,0,0,.07);--shadow-lg:0 6px 28px rgba(0,0,0,.12);
  --r:12px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Source Serif 4',Georgia,serif;background:var(--cream);color:var(--text);line-height:1.72;font-size:15px;}

/* ── COVER ── */
.cover{min-height:100vh;background:linear-gradient(150deg,#0d1e2e 0%,#102030 45%,#0a1f2e 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:60px 32px;position:relative;overflow:hidden;}
.cover::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 25% 35%,rgba(10,60,120,.35) 0%,transparent 55%),radial-gradient(ellipse at 75% 65%,rgba(10,80,140,.2) 0%,transparent 55%);}
.cover-watermark{position:absolute;bottom:20px;width:100%;text-align:center;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:rgba(255,255,255,.15);letter-spacing:.18em;text-transform:uppercase;}
.cover-logo{position:relative;width:140px;height:140px;border-radius:50%;overflow:hidden;border:3px solid rgba(255,255,255,.25);margin-bottom:22px;box-shadow:0 4px 30px rgba(0,0,0,.4);}
.cover-logo img{width:100%;height:100%;object-fit:cover;}
.cover h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,4.5vw,3.2rem);color:#f0f8ff;font-weight:700;line-height:1.12;margin-bottom:8px;position:relative;}
.cover h1 em{color:#7ab8ff;font-style:normal;}
.cover-badge{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.18);padding:5px 18px;border-radius:20px;font-family:'JetBrains Mono',monospace;font-size:.68rem;color:#a0d4ff;letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px;position:relative;display:inline-block;}
.cover-sub{font-size:.95rem;color:#88b0d0;margin-bottom:4px;position:relative;}
.cover-units{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;width:100%;max-width:680px;position:relative;margin:24px auto 0;}
.cu{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.13);border-radius:10px;padding:12px 16px;cursor:pointer;transition:all .2s;text-align:left;}
.cu:hover{background:rgba(255,255,255,.14);transform:translateY(-2px);}
.cu-num{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:#7ab8ff;letter-spacing:.12em;margin-bottom:3px;display:block;}
.cu-title{font-size:.82rem;color:#e0f0ff;font-weight:600;}

/* ── SEARCH ── */
.search-wrap{position:relative;margin:0 auto;width:100%;max-width:560px;margin-top:28px;}
.search-box{width:100%;padding:12px 20px 12px 46px;border-radius:30px;border:1.5px solid rgba(255,255,255,.22);background:rgba(255,255,255,.08);color:#f0f8ff;font-family:'Source Serif 4',serif;font-size:.95rem;outline:none;transition:all .22s;}
.search-box::placeholder{color:rgba(255,255,255,.35);}
.search-box:focus{border-color:rgba(120,180,255,.6);background:rgba(255,255,255,.13);}
.search-icon{position:absolute;left:16px;top:50%;transform:translateY(-50%);font-size:1rem;pointer-events:none;opacity:.5;color:white;}
.search-results{position:absolute;top:calc(100% + 8px);left:0;right:0;background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow-lg);max-height:340px;overflow-y:auto;z-index:500;display:none;}
.sr-item{padding:11px 18px;cursor:pointer;border-bottom:1px solid var(--border);transition:background .15s;}
.sr-item:last-child{border-bottom:none;}
.sr-item:hover{background:var(--warm);}
.sr-title{font-size:.88rem;font-weight:600;color:var(--text);}
.sr-ctx{font-size:.78rem;color:var(--muted);margin-top:2px;}
.sr-tag{font-family:'JetBrains Mono',monospace;font-size:.62rem;padding:1px 7px;border-radius:8px;margin-right:5px;font-weight:700;}
.sr-none{padding:14px 18px;font-size:.88rem;color:var(--muted);text-align:center;}
mark{background:#ffd060;border-radius:2px;padding:0 1px;}

/* ── STICKY NAV ── */
.sticky-nav{position:sticky;top:0;z-index:100;background:rgba(253,249,244,.96);backdrop-filter:blur(8px);border-bottom:1px solid var(--border);padding:7px 16px;display:flex;align-items:center;gap:5px;flex-wrap:wrap;}
.nav-btn{padding:4px 12px;border-radius:20px;border:1.5px solid var(--border);background:none;font-family:'Source Serif 4',serif;font-size:.74rem;color:var(--muted);cursor:pointer;transition:all .18s;white-space:nowrap;}
.nav-btn:hover{border-color:var(--blue);color:var(--blue);}
.nav-divider{width:1px;height:14px;background:var(--border);flex-shrink:0;}
.nav-search-btn{padding:4px 12px;border-radius:20px;border:1.5px solid var(--border);background:none;font-family:'Source Serif 4',serif;font-size:.74rem;color:var(--muted);cursor:pointer;transition:all .18s;white-space:nowrap;}
.nav-search-btn:hover{border-color:var(--purple);color:var(--purple);}
/* inline search bar in nav */
.nav-search-wrap{position:relative;margin-left:auto;display:flex;align-items:center;gap:6px;}
.nav-search-input{padding:4px 14px 4px 32px;border-radius:20px;border:1.5px solid var(--border);background:white;font-family:'Source Serif 4',serif;font-size:.75rem;color:var(--text);outline:none;width:180px;transition:all .22s;}
.nav-search-input:focus{border-color:var(--purple);width:240px;}
.nav-search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:.78rem;opacity:.4;pointer-events:none;}
.nav-sr-drop{position:absolute;top:calc(100% + 6px);right:0;width:360px;background:white;border:1px solid var(--border);border-radius:10px;box-shadow:var(--shadow-lg);max-height:320px;overflow-y:auto;z-index:600;display:none;}

/* ── PAGE ── */
.page{max-width:1060px;margin:0 auto;padding:48px 24px;}

/* ── CHAPTER HEADER ── */
.chapter-header{border-radius:var(--r);padding:30px 34px;margin-bottom:36px;position:relative;overflow:hidden;border:2px solid;}
.ch-u1{background:linear-gradient(135deg,#d6f0e0,#c0e8d0);border-color:#8ed4aa;color:var(--green);}
.ch-u2{background:linear-gradient(135deg,#d0e8ff,#b8daff);border-color:#7ab8f5;color:var(--blue);}
.ch-u3{background:linear-gradient(135deg,#ede0ff,#ddd0ff);border-color:#a080e8;color:var(--purple);}
.ch-u4{background:linear-gradient(135deg,#c8f0e8,#b0e8d8);border-color:#50b898;color:var(--teal);}
.chapter-header::after{content:attr(data-icon);position:absolute;right:28px;top:16px;font-size:4.5rem;opacity:.12;}
.ch-label{font-family:'JetBrains Mono',monospace;font-size:.68rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;opacity:.7;margin-bottom:6px;}
.chapter-header h2{font-family:'Playfair Display',serif;font-size:1.85rem;font-weight:700;margin-bottom:6px;}
.chapter-header p{font-size:.9rem;opacity:.75;}

/* ── LESSON HEADER ── */
.lesson-start{display:flex;align-items:center;gap:12px;margin:48px 0 20px;padding-bottom:12px;border-bottom:2px solid var(--border);}
.lesson-tag{font-family:'JetBrains Mono',monospace;font-size:.68rem;font-weight:700;padding:4px 12px;border-radius:20px;letter-spacing:.1em;white-space:nowrap;}
.lt-u1{background:var(--green-bg);color:var(--green);border:1px solid #8ed4aa;}
.lt-u2{background:var(--blue-bg);color:var(--blue);border:1px solid #7ab8f5;}
.lt-u3{background:var(--purple-bg);color:var(--purple);border:1px solid #9060d0;}
.lt-u4{background:var(--teal-bg);color:var(--teal);border:1px solid #40a080;}
.lesson-start h3{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--text);}

/* ── CONCEPT CARDS ── */
.card{background:white;border:1px solid var(--border);border-radius:var(--r);padding:22px 24px;margin-bottom:18px;box-shadow:var(--shadow);}
.card h4{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;margin-bottom:12px;color:var(--text);}

/* ── KEY BOX ── */
.kbox{border-radius:8px;padding:13px 17px;margin:10px 0;font-size:.9rem;border-left:4px solid;}
.kbox-green{background:var(--green-light);border-color:var(--green);color:#0d4a24;}
.kbox-blue{background:var(--blue-light);border-color:var(--blue);color:#062e57;}
.kbox-amber{background:var(--amber-light);border-color:var(--amber);color:#6b4800;}
.kbox-red{background:var(--red-light);border-color:var(--red);color:#5c0f0f;}
.kbox-purple{background:var(--purple-light);border-color:var(--purple);color:#36196e;}
.kbox-teal{background:var(--teal-light);border-color:var(--teal);color:#054a3c;}
.kbox-label{font-family:'JetBrains Mono',monospace;font-size:.64rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;display:block;margin-bottom:6px;opacity:.7;}

/* ── EQUATION ── */
.eq{background:#0f1420;color:#a0c8ff;border-radius:8px;padding:12px 18px;font-family:'JetBrains Mono',monospace;font-size:.85rem;margin:10px 0;border:1px solid #1e3060;line-height:1.85;}
.eq .ec{color:#5080a0;font-size:.78rem;}

/* ── TABLE ── */
.ctable{width:100%;border-collapse:collapse;margin:12px 0;font-size:.84rem;background:white;border-radius:10px;overflow:hidden;box-shadow:var(--shadow);}
.ctable th{background:var(--text);color:#f0ebe3;padding:9px 13px;text-align:left;font-family:'JetBrains Mono',monospace;font-size:.71rem;font-weight:600;letter-spacing:.05em;}
.ctable td{padding:8px 13px;border-bottom:1px solid var(--border);}
.ctable tr:last-child td{border-bottom:none;}
.ctable tr:hover td{background:var(--warm);}

/* ── GRID ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:14px 0;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin:14px 0;}
@media(max-width:680px){.g2,.g3{grid-template-columns:1fr;}}
.mini{background:white;border:1px solid var(--border);border-radius:10px;padding:15px 17px;font-size:.86rem;}
.mini .mh{font-family:'JetBrains Mono',monospace;font-size:.7rem;font-weight:700;color:var(--muted);border-bottom:1px solid var(--border);padding-bottom:6px;margin-bottom:8px;}
.mini ul{padding-left:18px;}
.mini li{margin-bottom:4px;color:var(--muted);}

/* ── MISTAKE BOX ── */
.mistake-section{background:linear-gradient(135deg,#fff5f5,#ffe8e8);border:2px solid #e88080;border-radius:var(--r);padding:20px 24px;margin:20px 0;}
.mistake-section .ms-head{font-family:'JetBrains Mono',monospace;font-size:.68rem;font-weight:700;letter-spacing:.12em;color:var(--red);text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.mistake-item{background:white;border:1px solid #e0a0a0;border-radius:8px;padding:12px 15px;margin-bottom:10px;font-size:.87rem;}
.mistake-item:last-child{margin-bottom:0;}
.mi-wrong{color:var(--red);font-weight:700;margin-bottom:4px;}
.mi-right{color:var(--green);font-weight:700;margin-bottom:4px;}
.mi-explain{color:var(--muted);font-size:.83rem;}

/* ── EXERCISE SECTION ── */
.ex-section{background:white;border:1px solid var(--border);border-radius:var(--r);padding:22px 24px;margin:20px 0;box-shadow:var(--shadow);}
.ex-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border);}
.ex-title{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;}
.ex-level{font-family:'JetBrains Mono',monospace;font-size:.67rem;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:.08em;}
.el-easy{background:var(--green-bg);color:var(--green);}
.el-medium{background:var(--amber-bg);color:var(--amber);}
.el-hard{background:var(--red-bg);color:var(--red);}
.ex-q{background:var(--warm);border-radius:8px;padding:13px 16px;margin-bottom:12px;font-size:.9rem;}
.ex-qnum{font-family:'JetBrains Mono',monospace;font-size:.68rem;font-weight:700;color:var(--muted);margin-bottom:5px;}
.ex-opts{margin-top:8px;display:flex;flex-direction:column;gap:5px;}
.ex-opt{font-size:.87rem;color:var(--muted);cursor:pointer;padding:6px 10px;border-radius:6px;border:1.5px solid var(--border);background:white;text-align:left;font-family:'Source Serif 4',serif;transition:all .18s;display:flex;gap:8px;align-items:flex-start;}
.ex-opt:hover{border-color:var(--green);background:var(--green-light);}
.ex-opt.correct{border-color:var(--green);background:var(--green-light);color:#0d4a24;font-weight:600;}
.ex-opt.wrong{border-color:var(--red);background:var(--red-light);color:#5c0f0f;}
.ex-opt.disabled{pointer-events:none;}
.opt-let{font-family:'JetBrains Mono',monospace;font-size:.71rem;font-weight:700;min-width:18px;padding-top:1px;flex-shrink:0;color:var(--light);}
.ex-feedback{display:none;margin-top:8px;border-radius:6px;padding:10px 13px;font-size:.84rem;}
.fb-correct{background:var(--green-bg);color:#0d4a24;border-left:3px solid var(--green);}
.fb-wrong{background:var(--red-bg);color:#5c0f0f;border-left:3px solid var(--red);}

/* ── PAST EXAM ── */
.past-section{background:linear-gradient(135deg,#f0f6ff,#e4eeff);border:2px solid #8ab0e8;border-radius:var(--r);padding:20px 24px;margin:20px 0;}
.past-head{font-family:'JetBrains Mono',monospace;font-size:.68rem;font-weight:700;letter-spacing:.12em;color:var(--blue);text-transform:uppercase;margin-bottom:14px;}
.past-q{background:white;border:1px solid #b0c8f0;border-radius:8px;padding:13px 16px;margin-bottom:10px;font-size:.88rem;}
.past-q:last-child{margin-bottom:0;}
.past-src{font-family:'JetBrains Mono',monospace;font-size:.63rem;font-weight:700;color:var(--blue);background:var(--blue-bg);padding:2px 8px;border-radius:10px;display:inline-block;margin-bottom:6px;}
.past-opts{margin-top:8px;display:flex;flex-direction:column;gap:4px;}
.past-opt{font-size:.85rem;color:var(--muted);padding:5px 10px;border-radius:5px;border:1px solid #ccd8ef;background:#f7faff;cursor:pointer;font-family:'Source Serif 4',serif;display:flex;gap:8px;transition:all .18s;}
.past-opt:hover{border-color:var(--blue);background:var(--blue-light);}
.past-opt.correct{border-color:var(--green);background:var(--green-light);color:#0d4a24;font-weight:600;}
.past-opt.wrong{border-color:var(--red);background:var(--red-light);color:#5c0f0f;}
.past-opt.disabled{pointer-events:none;}

/* ── CHAPTER SUMMARY ── */
.summary-section{background:linear-gradient(135deg,#f0faf4,#e4f5ea);border:2px solid #80c898;border-radius:var(--r);padding:26px 28px;margin:32px 0;}
.sum-head{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--green);margin-bottom:16px;}
.must-own-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
@media(max-width:640px){.must-own-grid{grid-template-columns:1fr;}}
.must-item{background:white;border:1px solid #a8d8b8;border-radius:8px;padding:12px 15px;font-size:.86rem;}
.must-item .mi-title{font-weight:700;color:var(--green);margin-bottom:4px;font-size:.88rem;}
.must-item .mi-body{color:var(--muted);}

/* ── CHAPTER REVIEW ── */
.review-section{background:white;border:2px solid var(--border2);border-radius:var(--r);padding:26px 28px;margin:28px 0;box-shadow:var(--shadow-lg);}
.review-head{font-family:'Playfair Display',serif;font-size:1.25rem;font-weight:700;color:var(--text);margin-bottom:18px;padding-bottom:12px;border-bottom:2px solid var(--border);}
.review-q{border-radius:8px;padding:14px 17px;margin-bottom:14px;border:1px solid var(--border);background:var(--warm);}
.rq-top{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.rq-num{font-family:'JetBrains Mono',monospace;font-size:.7rem;font-weight:700;color:white;background:var(--text);padding:2px 8px;border-radius:10px;}
.rq-lvl{font-family:'JetBrains Mono',monospace;font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:10px;letter-spacing:.06em;}
.rq-text{font-size:.9rem;margin-bottom:8px;}

/* ── EXAM TIP ── */
.etip{background:linear-gradient(135deg,#fffae8,#fff3cc);border:1.5px solid #ddb820;border-radius:10px;padding:13px 17px;margin:12px 0;}
.etip::before{content:'⚠ EXAM TIP · ';font-family:'JetBrains Mono',monospace;font-size:.63rem;font-weight:700;color:var(--amber);letter-spacing:.1em;}
.etip p{font-size:.87rem;color:#6b4800;display:inline;}

/* ── DIVIDERS ── */
.sdiv{text-align:center;position:relative;margin:40px 0;}
.sdiv::before{content:'';position:absolute;top:50%;left:0;right:0;height:1px;background:var(--border2);}
.sdiv span{background:var(--cream);padding:0 16px;position:relative;font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--light);letter-spacing:.1em;}

/* ── BACK TO TOP ── */
.btt{position:fixed;bottom:22px;right:22px;background:linear-gradient(135deg,#0a4d8c,#1a7a3c);color:white;width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;cursor:pointer;border:none;box-shadow:0 3px 14px rgba(0,0,0,.25);transition:all .2s;z-index:999;opacity:.85;}
.btt:hover{transform:translateY(-3px);opacity:1;}

/* ── LAST PAGE ── */
.last-page{min-height:70vh;background:linear-gradient(150deg,#0d1e2e 0%,#102030 50%,#0a1a28 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:60px 32px;position:relative;overflow:hidden;}
.last-page::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 40%,rgba(10,60,120,.3) 0%,transparent 55%);}
.lp-icon{font-size:3.5rem;margin-bottom:16px;position:relative;}
.lp-text{font-family:'Playfair Display',serif;font-size:1.8rem;color:#e8f4ff;font-weight:700;margin-bottom:8px;position:relative;}
.lp-sub{font-size:.9rem;color:#88b0cc;margin-bottom:5px;position:relative;}
.lp-owner{font-family:'JetBrains Mono',monospace;font-size:.95rem;color:#7ab8ff;letter-spacing:.16em;margin-top:18px;position:relative;}
.lp-links{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-top:24px;position:relative;}
.lp-link{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.2);border-radius:10px;padding:12px 22px;color:#c0d8f0;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:.78rem;letter-spacing:.06em;transition:all .2s;display:flex;align-items:center;gap:8px;}
.lp-link:hover{background:rgba(255,255,255,.16);border-color:rgba(120,180,255,.5);color:#e0f0ff;transform:translateY(-2px);}
.lp-watermark{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:rgba(255,255,255,.12);letter-spacing:.18em;margin-top:32px;position:relative;}

/* ── SEARCH HIGHLIGHT ── */
.search-highlight{background:#ffd060;border-radius:2px;padding:0 2px;}


/* ── VIS SCROLL ── */
.vis-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;}

/* ── SIDEBAR ── */
.sidebar{
  position:fixed;left:-280px;top:0;bottom:0;width:280px;
  background:white;border-right:1px solid var(--border);
  z-index:200;transition:left .28s cubic-bezier(.4,0,.2,1);
  overflow-y:auto;box-shadow:4px 0 20px rgba(0,0,0,.1);
  display:flex;flex-direction:column;
}
.sidebar.open{left:0;}
.sidebar-head{
  padding:16px 18px 12px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  flex-shrink:0;background:var(--cream);position:sticky;top:0;z-index:1;
}
.sidebar-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--text);}
.sidebar-close{background:none;border:none;cursor:pointer;font-size:1.1rem;color:var(--muted);padding:4px;}
.sidebar-body{flex:1;overflow-y:auto;padding:8px 0;}
.sb-ch{font-family:'JetBrains Mono',monospace;font-size:.67rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;color:white;
  padding:8px 18px 6px;margin-top:4px;cursor:pointer;}
.sb-ch.c1{background:var(--green);}
.sb-ch.c2{background:var(--blue);}
.sb-ch.c3{background:var(--purple);}
.sb-ch.c4{background:var(--teal);}
.sb-lesson{
