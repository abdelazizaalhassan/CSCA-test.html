<script>

// ══ UNIFIED ANSWER CHECKERS ══
function checkAns(btn, chosen, correct, msg) {
  const q = btn.closest('.ex-q, .review-q');
  if (!q || q.dataset.done) return;
  q.dataset.done = 'true';
  const opts = q.querySelectorAll('.ex-opt');
  opts.forEach(o => o.classList.add('disabled'));
  if (opts[correct]) opts[correct].classList.add('correct');
  if (chosen !== correct) btn.classList.add('wrong');
  let fb = q.querySelector('.ex-feedback');
  if (!fb) { fb = document.createElement('div'); q.appendChild(fb); }
  fb.textContent = msg;
  fb.className = 'ex-feedback ' + (chosen === correct ? 'fb-correct' : 'fb-wrong');
  fb.style.display = 'block';
}

function pastCheck(btn, chosen, correct, msg) {
  const q = btn.closest('.past-q');
  if (!q || q.dataset.done) return;
  q.dataset.done = 'true';
  const opts = q.querySelectorAll('.past-opt');
  opts.forEach(o => o.classList.add('disabled'));
  if (opts[correct]) opts[correct].classList.add('correct');
  if (chosen !== correct) btn.classList.add('wrong');
  let fb = q.querySelector('.ex-feedback');
  if (!fb) { fb = document.createElement('div'); q.appendChild(fb); }
  fb.textContent = msg;
  fb.className = 'ex-feedback ' + (chosen === correct ? 'fb-correct' : 'fb-wrong');
  fb.style.display = 'block';
}

// Alias for Units 3&4 (uses chk/pchk)
function chk(btn, chosen, correct, msg) { checkAns(btn, chosen, correct, msg); }
function pchk(btn, chosen, correct, msg) { pastCheck(btn, chosen, correct, msg); }

// ══ SEARCH ENGINE ══
let searchIndex = [];

function buildIndex() {
  // Index every heading, kbox, card, lesson, past-q, mistake-item, must-item
  const sections = [
    { sel: '.lesson-start h3', type: 'Lesson' },
    { sel: '.chapter-header h2', type: 'Chapter' },
    { sel: '.card h4', type: 'Concept' },
    { sel: '.kbox', type: 'Key Point' },
    { sel: '.etip', type: 'Exam Tip' },
    { sel: '.mi-wrong, .mi-right', type: 'Common Mistake' },
    { sel: '.past-q', type: 'Past Exam Q' },
    { sel: '.ex-q', type: 'Exercise' },
    { sel: '.must-item', type: 'Summary' },
    { sel: '.mistake-item', type: 'Mistake' },
    { sel: '.eq', type: 'Equation' },
    { sel: '.ctable tr', type: 'Table Row' },
  ];

  sections.forEach(s => {
    document.querySelectorAll(s.sel).forEach(el => {
      const text = el.innerText.trim().replace(/\s+/g,' ');
      if (text.length < 5) return;
      // Find nearest anchor
      let anchor = el.closest('[id]');
      if (!anchor) {
        // go up the DOM to find a parent with id
        let p = el.parentElement;
        while (p && !p.id) p = p.parentElement;
        anchor = p;
      }
      const id = anchor ? anchor.id : '';
      // Get section label
      let label = '';
      const lessonEl = el.closest('.page');
      if (lessonEl) {
        const lh = lessonEl.querySelector('.chapter-header h2');
        if (lh) label = lh.innerText.slice(0,30);
      }
      searchIndex.push({
        type: s.type,
        text: text.slice(0, 200),
        id: id,
        label: label,
        el: el
      });
    });
  });
}

function doSearch(q, dropId) {
  const drop = document.getElementById(dropId);
  if (!q || q.trim().length < 2) { drop.style.display='none'; return; }
  if (searchIndex.length === 0) buildIndex();

  const terms = q.toLowerCase().trim().split(/\s+/);
  const results = [];

  searchIndex.forEach(item => {
    const txt = item.text.toLowerCase();
    const score = terms.reduce((s, t) => s + (txt.includes(t) ? (txt.indexOf(t) < 50 ? 3 : 1) : 0), 0);
    if (score > 0) results.push({...item, score});
  });

  results.sort((a,b) => b.score - a.score);
  const top = results.slice(0, 12);

  if (top.length === 0) {
    drop.innerHTML = '<div class="sr-none">No results found for "' + q + '"</div>';
    drop.style.display = 'block';
    return;
  }

  const typeColors = {
    'Chapter':'#1a7a3c','Lesson':'#0a4d8c','Concept':'#5a2d9a',
    'Key Point':'#0a7a64','Exam Tip':'#b07800','Common Mistake':'#a01c1c',
    'Past Exam Q':'#0a4d8c','Exercise':'#1a7a3c','Summary':'#1a7a3c',
    'Mistake':'#a01c1c','Equation':'#5a2d9a','Table Row':'#6b5040'
  };
  const typeBg = {
    'Chapter':'#d6f0e0','Lesson':'#d0e8ff','Concept':'#ede0ff',
    'Key Point':'#c8f0e8','Exam Tip':'#fff2c2','Common Mistake':'#ffd8d8',
    'Past Exam Q':'#d0e8ff','Exercise':'#d6f0e0','Summary':'#d6f0e0',
    'Mistake':'#ffd8d8','Equation':'#ede0ff','Table Row':'#f0ede8'
  };

  function highlight(text, terms) {
    let result = text.slice(0, 120);
    terms.forEach(t => {
      const re = new RegExp('(' + t.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')', 'gi');
      result = result.replace(re, '<mark>$1</mark>');
    });
    return result;
  }

  drop.innerHTML = top.map(r => {
    const bg = typeBg[r.type] || '#f0f0f0';
    const col = typeColors[r.type] || '#333';
    const snippet = highlight(r.text, terms);
    return `<div class="sr-item" onclick="jumpTo('${r.id}','${dropId}')">
      <div class="sr-title">
        <span class="sr-tag" style="background:${bg};color:${col}">${r.type}</span>
        ${r.label ? '<span style="font-size:.72rem;color:#9c7f60">· '+r.label.slice(0,24)+'</span>' : ''}
      </div>
      <div class="sr-ctx">${snippet}${r.text.length>120?'…':''}</div>
    </div>`;
  }).join('');

  drop.style.display = 'block';
}

function jumpTo(id, dropId) {
  hideDrop(dropId);
  if (!id) return;
  const el = document.getElementById(id);
  if (el) {
    el.scrollIntoView({behavior:'smooth', block:'start'});
    el.style.outline = '3px solid #ffd060';
    el.style.borderRadius = '8px';
    setTimeout(() => { el.style.outline = ''; el.style.borderRadius = ''; }, 2200);
  }
}

function hideDrop(id) {
  const d = document.getElementById(id);
  if (d) d.style.display = 'none';
}

// Build index on load
window.addEventListener('load', () => { setTimeout(buildIndex, 600); });

// BTT opacity
window.addEventListener('scroll', () => {
  document.querySelector('.btt').style.opacity = window.scrollY > 400 ? '0.9' : '0.4';
});

// Close search when clicking outside
document.addEventListener('click', (e) => {
  if (!e.target.closest('.search-wrap') && !e.target.closest('.nav-search-wrap')) {
    hideDrop('coverDrop'); hideDrop('navDrop');
  }
});


