  <table class="ctable">
    <tr><th>Gas</th><th>Reagents & Method</th><th>Equation</th><th>Purification</th></tr>
    <tr><td><strong>H₂</strong></td><td>Zn + dilute H₂SO₄ (or HCl) at room temperature</td><td>Zn + H₂SO₄ → ZnSO₄ + H₂↑</td><td>Bubble through NaOH(aq) to remove HCl; dry with conc. H₂SO₄</td></tr>
    <tr><td><strong>O₂</strong> (method 1)</td><td>KClO₃ + MnO₂ catalyst, heat (Δ)</td><td>2KClO₃ →(MnO₂, Δ) 2KCl + 3O₂↑</td><td>Usually collected directly</td></tr>
    <tr><td><strong>O₂</strong> (method 2)</td><td>H₂O₂ + MnO₂ catalyst (no heat needed)</td><td>2H₂O₂ →(MnO₂) 2H₂O + O₂↑</td><td>Milder; lab preferred</td></tr>
    <tr><td><strong>CO₂</strong></td><td>Marble (CaCO₃) + dilute HCl (room temperature)</td><td>CaCO₃ + 2HCl → CaCl₂ + H₂O + CO₂↑</td><td>Bubble through NaHCO₃(aq) to remove HCl gas; dry with conc. H₂SO₄</td></tr>
